{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist/server",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/server/**/*",
    "src/lib/**/*",
    "src/crawler/**/*",
    "src/vendors.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}