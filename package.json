{
  "name": "doc-speak-rag",
  "version": "1.0.0",
  "description": "Native Local Modular RAG System",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run crawler:watch\" \"npm run server:dev\"",
    "build": "npm run server:build && npm run crawler:build",
    "start": "node dist/server/index.js",
    "server:dev": "ts-node src/server/index.ts",
    "server:build": "tsc --project tsconfig.server.json",
    "crawler:build": "tsc --project tsconfig.crawler.json",
    "crawler:watch": "tsc --watch --project tsconfig.crawler.json",
    "crawler:run": "node dist/crawler/index.js",
    "setup": "node scripts/setup.js",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "ingest:all": "node dist/cli/ingest.js all",
    "vendors:list": "node dist/cli/vendors.js list",
    "ingest:vendor": "node dist/cli/ingest.js"
  },
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "chromadb": "^3.4.0",
    "crawlee": "^3.10.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "postcss": "^8.5.8",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2"
  }
}
