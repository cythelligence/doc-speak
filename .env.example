# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ChromaDB Configuration
CHROMA_DATA_PATH=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false

# Microsoft Copilot Configuration
COPILOT_API_KEY=your_copilot_api_key_here
COPILOT_ENDPOINT=https://api.openai.com/v1
COPILOT_MODEL=gemini-2.5-flash

# LLM Provider (ollama or copilot)
LLM_PROVIDER=ollama

# Crawler Configuration
RAG_DATA_PATH=/Users/portoro/Documents/RAG-Data
CRAWLER_USER_AGENT=Mozilla/5.0 (macOS; Intel Mac OS X 10_15_7) AppleWebKit/537.36

# Database
DATABASE_URL=file:./chroma_data/chat.db

# App Configuration
NODE_ENV=local

